rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Coleção "config" — armazena configurações dos PDFs
    // Leitura pública (site precisa carregar os links dos PDFs)
    // Escrita apenas para administradores autenticados
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Coleção "adminNotifications" — armazena disparos de notificações push
    // Leitura pública (site precisa carregar os avisos para o letreiro/histórico)
    // Escrita apenas para administradores autenticados
    match /adminNotifications/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Coleção "fcmTokens" — armazena os tokens de notificação dos usuários
    // Leitura não é necessária para o público
    // Escrita é permitida para qualquer um poder se registrar
    match /fcmTokens/{document} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Coleção "adminLogs" — armazena o histórico de ações do painel admin
    // Leitura e Escrita apenas para administradores autenticados
    match /adminLogs/{document} {
      allow read, write: if request.auth != null;
    }

    // Coleção "dynamicLinks" — armazena os botões temporários
    // Leitura pública e escrita apenas para administradores autenticados
    match /dynamicLinks/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Coleção "scheduledNotifications" — armazena avisos agendados
    // Leitura e Escrita apenas para administradores autenticados
    match /scheduledNotifications/{document} {
      allow read, write: if request.auth != null;
    }

    // Coleção "medicalCertificates" — armazena metadados dos atestados processados
    // Leitura e Escrita apenas para administradores autenticados
    match /medicalCertificates/{document} {
      allow read, write: if request.auth != null;
    }

    // Coleção "settings" — configurações globais do sistema
    // Leitura pública (para verificar se atestados estão ativos)
    match /settings/atestados {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regra padrão — nega tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
