rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    // PDFs públicos (Agenda, Temporada)
    match /pdfs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Imagens de notificações
    match /notification_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pasta temporária para upload de atestados (Músicos enviam aqui)
    match /atestados_temp/{allPaths=**} {
      allow write: if true; // Permite upload público (músicos)
      allow read: if request.auth != null; // Apenas admin lê
    }

    // Pasta de atestados processados (Contém dados sensíveis)
    match /atestados_processed/{allPaths=**} {
      allow read, write: if request.auth != null; // Totalmente privado (Admin only)
    }

    // Regra padrão para outros caminhos (segurança básica)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
